{
  "manifest_version": 3,
  "name": "SIASE Plus",
  "version": "0.1.0",
  "description": "Modern UI, quick dashboard, grade alerts, calendar export, and smart navigation for UANL SIASE.",
  "action": { "default_title": "SIASE Plus", "default_popup": "src/popup/popup.html" },
  "icons": { "16": "icons/icon-16.png", "32": "icons/icon-32.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" },
  "background": { "service_worker": "src/background/service-worker.ts", "type": "module" },
  "permissions": ["alarms", "notifications", "storage", "downloads"],
  "host_permissions": ["https://deimos.dgi.uanl.mx/*"],
  "content_scripts": [
    {
      "matches": ["https://deimos.dgi.uanl.mx/*default.htm*"],
      "js": ["src/content/frameset-injector.ts"],
      "all_frames": false,
      "run_at": "document_start"
    },
    {
      "matches": ["https://deimos.dgi.uanl.mx/*maintop.htm*"],
      "js": ["src/content/top-frame.ts"],
      "css": ["src/content/styles/top.css"],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": ["https://deimos.dgi.uanl.mx/*mainleftdin01.htm*"],
      "js": ["src/content/left-frame.ts"],
      "css": ["src/content/styles/left.css"],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": ["https://deimos.dgi.uanl.mx/*maincenter.htm*"],
      "js": ["src/content/center-frame.ts"],
      "css": ["src/content/styles/center.css"],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/econcfs01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/echalm01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/econkdx01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/edatal01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/ecohoinsint01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/ecSitEst01.htm*"
      ],
      "js": ["src/content/router.ts"],
      "css": ["src/content/styles/center.css"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [{ "resources": ["src/content/styles/shadow.css", "icons/*.png"], "matches": ["https://deimos.dgi.uanl.mx/*"] }]
}
