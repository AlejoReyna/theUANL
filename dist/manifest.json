{
  "manifest_version": 3,
  "name": "SIASE Plus",
  "version": "0.1.0",
  "description": "Modern UI, quick dashboard, grade alerts, calendar export, and smart navigation for UANL SIASE.",
  "action": {
    "default_title": "SIASE Plus",
    "default_popup": "src/popup/popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://deimos.dgi.uanl.mx/*"
  ],
  "content_scripts": [
    {
      "js": [
        "assets/frameset-injector.ts-loader-C8OiZ3M-.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*default.htm*"
      ],
      "all_frames": false,
      "run_at": "document_start"
    },
    {
      "js": [
        "assets/top-frame.ts-loader-XfHOQ2rA.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*maintop.htm*"
      ],
      "css": [
        "src/content/styles/top.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/left-frame.ts-loader-BHk27-ad.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*mainleftdin01.htm*"
      ],
      "css": [
        "src/content/styles/left.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/center-frame.ts-loader-ZKs4y_JK.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*maincenter.htm*"
      ],
      "css": [
        "src/content/styles/center.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/career-landing.ts-loader-BC--dpl5.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/eselcarrera.htm*"
      ],
      "css": [
        "src/content/styles/center.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/router.ts-loader-Cnru1r2F.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/econcfs01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/echalm01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/econkdx01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/edatal01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/ecohoinsint01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/ecSitEst01.htm*"
      ],
      "css": [
        "src/content/styles/center.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://deimos.dgi.uanl.mx/*"
      ],
      "resources": [
        "src/content/styles/shadow.css",
        "icons/*.png",
        "assets/single-view-layout-BkYzni2q.js",
        "assets/single-view-layout-BkYzni2q.js.map",
        "assets/frameset-injector.ts-BRF_yYeh.js",
        "assets/frameset-injector.ts-BRF_yYeh.js.map",
        "assets/dom-3YFWrmpq.js",
        "assets/dom-3YFWrmpq.js.map",
        "assets/storage-CGf68QnW.js",
        "assets/storage-CGf68QnW.js.map",
        "assets/top-frame.ts-Wzbjb-7f.js",
        "assets/top-frame.ts-Wzbjb-7f.js.map",
        "assets/jsx-runtime-18NIdeNA.js",
        "assets/jsx-runtime-18NIdeNA.js.map",
        "assets/left-frame.ts-BL9UdBb2.js",
        "assets/left-frame.ts-BL9UdBb2.js.map",
        "assets/center-ui-BTk3QlLo.js",
        "assets/center-ui-BTk3QlLo.js.map",
        "assets/theme-DGOVaEIk.js",
        "assets/theme-DGOVaEIk.js.map",
        "assets/center-frame.ts-Bj9rilB0.js",
        "assets/center-frame.ts-Bj9rilB0.js.map",
        "assets/career-landing.ts-DDiM3apu.js",
        "assets/career-landing.ts-DDiM3apu.js.map"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*"
      ],
      "resources": [
        "assets/center-ui-BTk3QlLo.js",
        "assets/center-ui-BTk3QlLo.js.map",
        "assets/dom-3YFWrmpq.js",
        "assets/dom-3YFWrmpq.js.map",
        "assets/storage-CGf68QnW.js",
        "assets/storage-CGf68QnW.js.map",
        "assets/theme-DGOVaEIk.js",
        "assets/theme-DGOVaEIk.js.map",
        "assets/router.ts-DBR5AR5e.js",
        "assets/router.ts-DBR5AR5e.js.map"
      ],
      "use_dynamic_url": false
    }
  ]
}
