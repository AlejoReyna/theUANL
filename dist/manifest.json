{
  "manifest_version": 3,
  "name": "SIASE Plus",
  "version": "0.1.0",
  "description": "Modern UI, quick dashboard, grade alerts, calendar export, and smart navigation for UANL SIASE.",
  "action": {
    "default_title": "SIASE Plus",
    "default_popup": "src/popup/popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://deimos.dgi.uanl.mx/*"
  ],
  "content_scripts": [
    {
      "js": [
        "assets/frameset-injector.ts-B762IZ76.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*default.htm*"
      ],
      "all_frames": false,
      "run_at": "document_start"
    },
    {
      "js": [
        "assets/top-frame.ts-loader-CT7tilyI.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*maintop.htm*"
      ],
      "css": [
        "src/content/styles/top.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/left-frame.ts-loader-DKLEWqun.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*mainleftdin01.htm*"
      ],
      "css": [
        "src/content/styles/left.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/center-frame.ts-BxnQZ0J_.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*maincenter.htm*"
      ],
      "css": [
        "src/content/styles/center.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/router.ts-loader-Bq8hNk7W.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/econcfs01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/echalm01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/econkdx01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/edatal01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/ecohoinsint01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/ecSitEst01.htm*"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://deimos.dgi.uanl.mx/*"
      ],
      "resources": [
        "src/content/styles/shadow.css",
        "icons/*.png",
        "assets/frameset-injector.ts-B762IZ76.js",
        "assets/frameset-injector.ts-B762IZ76.js.map",
        "assets/dom-DsnxF-Y-.js",
        "assets/dom-DsnxF-Y-.js.map",
        "assets/storage-CGf68QnW.js",
        "assets/storage-CGf68QnW.js.map",
        "assets/top-frame.ts-C07y4Fcc.js",
        "assets/top-frame.ts-C07y4Fcc.js.map",
        "assets/jsx-runtime-C7ZK4u-l.js",
        "assets/jsx-runtime-C7ZK4u-l.js.map",
        "assets/left-frame.ts-QdLksC_z.js",
        "assets/left-frame.ts-QdLksC_z.js.map",
        "assets/center-frame.ts-BxnQZ0J_.js",
        "assets/center-frame.ts-BxnQZ0J_.js.map"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*"
      ],
      "resources": [
        "assets/dom-DsnxF-Y-.js",
        "assets/dom-DsnxF-Y-.js.map",
        "assets/storage-CGf68QnW.js",
        "assets/storage-CGf68QnW.js.map",
        "assets/router.ts-DBtYgAWO.js",
        "assets/router.ts-DBtYgAWO.js.map"
      ],
      "use_dynamic_url": false
    }
  ]
}
